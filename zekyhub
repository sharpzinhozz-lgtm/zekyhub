            a.aim = not a.aim
            aimToggle.Text = a.aim and "ON" or "OFF"
            aimToggle.BackgroundColor3 = a.aim and Color3RGB(0, 150, 0) or Color3RGB(150, 50, 50)
            if not a.aim then currentTarget = nil end
        else
            a.aim = true
            aimToggle.Text = "ON"
            aimToggle.BackgroundColor3 = Color3RGB(0, 150, 0)
        end
    end
    
    if input.KeyCode == Enum.KeyCode.F6 then
        g.Enabled = not g.Enabled
    end
end)

