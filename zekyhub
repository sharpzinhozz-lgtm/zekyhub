-- ========== FUNÇÃO PARA CRIAR GUI COM FALLBACK ==========
local function createGui()
    local success, parent = pcall(function()
        local test = Instance.new("ScreenGui")
        test.Parent = CoreGui
        test:Destroy()
        return CoreGui
    end)
    
    if success then
        return CoreGui
    else
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            return playerGui
        else
            local newGui = Instance.new("ScreenGui")
            newGui.Parent = LocalPlayer
            return newGui
        end
    end
end

