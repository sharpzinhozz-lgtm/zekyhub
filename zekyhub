    local nameLabel = Instance.new("TextLabel", bg)
    nameLabel.Size = UDim2New(1, 0, 0.6, 0)
    nameLabel.Position = UDim2New(0, 0, 0, 2)
    nameLabel.BackgroundTransparency = 1
