    title.TextColor3 = Color3RGB(0, 255, 200)
    title.TextSize = 28
    title.Font = Enum.Font.GothamBold
    
    local loadingText = Instance.new("TextLabel", frame)
    loadingText.Size = UDim2New(1, 0, 0, 30)
    loadingText.Position = UDim2New(0, 0, 0, 80)
    loadingText.BackgroundTransparency = 1
    loadingText.Text = "INICIANDO..."
    loadingText.TextColor3 = Color3RGB(255, 255, 255)
    loadingText.TextSize = 14
    
    local barBg = Instance.new("Frame", frame)
    barBg.Size = UDim2New(0.8, 0, 0, 6)
    barBg.Position = UDim2New(0.1, 0, 0, 120)
    barBg.BackgroundColor3 = Color3RGB(30, 30, 40)
    Instance.new("UICorner", barBg).CornerRadius = UDim.new(0, 3)
    
    local barFill = Instance.new("Frame", barBg)
    barFill.Size = UDim2New(0, 0, 1, 0)
    barFill.BackgroundColor3 = Color3RGB(0, 255, 200)
    Instance.new("UICorner", barFill).CornerRadius = UDim.new(0, 3)
    
    -- Animação rápida
    for i = 1, 10 do
        barFill.Size = UDim2New(i/10, 0, 1, 0)
        loadingText.Text = i == 10 and "PRONTO!" or "CARREGANDO "..(i*10).."%"
        RunService.Heartbeat:Wait()
    end
    
    wait(0.2)
    loadingGui:Destroy()
end

