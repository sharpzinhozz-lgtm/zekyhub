UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    if listeningForKey and input.KeyCode ~= Enum.KeyCode.Unknown then
        a.keybind = input.KeyCode
        keyBtn.Text = tostring(input.KeyCode):gsub("Enum.KeyCode.", ""):sub(1, 2)
        keyBtn.BackgroundColor3 = Color3RGB(30, 30, 40)
        listeningForKey = false
    end
    
    if input.KeyCode == a.keybind then
        if a.keyMode == "TOGGLE" then
            a.aim = not a.aim
            aimToggle.Text = a.aim and "ON" or "OFF"
            aimToggle.BackgroundColor3 = a.aim and Color3RGB(0, 100, 0) or Color3RGB(100, 40, 40)
            if not a.aim then currentTarget = nil end
        else
            a.aim = true
            aimToggle.Text = "ON"
            aimToggle.BackgroundColor3 = Color3RGB(0, 100, 0)
        end
    end
    
    if input.KeyCode == Enum.KeyCode.F6 then
        g.Enabled = not g.Enabled
    end
end)

UserInputService.InputEnded:Connect(function(input, gp)
    if gp then return end
    
    if a.keyMode == "HOLD" and input.KeyCode == a.keybind then
        a.aim = false
        aimToggle.Text = "OFF"
        aimToggle.BackgroundColor3 = Color3RGB(100, 40, 40)
        currentTarget = nil
    end
end)

-- Silent Aim
if getrawmetatable then
    local mt = getrawmetatable(game)
    local old = mt.__namecall
    setreadonly(mt, false)
    mt.__namecall = function(self, ...)
        local args = {...}
        local method = getnamecallmethod()
        if a.silent and currentTarget and (method == "FireServer" or method == "InvokeServer") then
            local parte = currentTarget.Character and (currentTarget.Character:FindFirstChild(a.hitpart) or currentTarget.Character:FindFirstChild("HumanoidRootPart"))
            if parte then
                for i = 1, #args do
                    if type(args[i]) == "Vector3" then
                        args[i] = parte.Position
                        break
                    end
                end
            end
        end
        return old(self, unpack(args))
    end
    setreadonly(mt, true)
end

