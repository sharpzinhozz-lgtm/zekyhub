-- ========== FUNÇÕES DE INTERFACE (REUTILIZÁVEIS) ==========
local function criarToggle(parent, texto, estado, y)
    local bg = Instance.new("Frame", parent)
    bg.Size = UDim2New(0.95, 0, 0, 24)
    bg.Position = UDim2New(0, 0, 0, y)
    bg.BackgroundTransparency = 1
    bg.Name = "ToggleFrame"
    
    local label = Instance.new("TextLabel", bg)
    label.Size = UDim2New(0.7, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = texto
    label.TextColor3 = Color3RGB(200, 200, 200)
    label.TextSize = 10
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    
    local btn = Instance.new("TextButton", bg)
    btn.Size = UDim2New(0.18, 0, 0, 20)
    btn.Position = UDim2New(0.77, 0, 0.5, -10)
    btn.BackgroundColor3 = estado and Color3RGB(0, 120, 0) or Color3RGB(120, 40, 40)
    btn.Text = estado and "ON" or "OFF"
    btn.TextColor3 = Color3RGB(255, 255, 255)
    btn.TextSize = 9
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    
    return btn
end

