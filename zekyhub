    -- Verifica se é uma fruta
    local nome = obj.Name:lower()
    local isFruit = nome:find("fruit") or nome:find("fruta") or nome:find("apple") or nome:find("banana") 
        or nome:find("magu") or nome:find("gomu") or nome:find("mera") 
        or obj:IsA("Tool") or obj:IsA("Part") or obj:IsA("MeshPart")
    
