rs.RenderStepped:Connect(function()
    -- ATUALIZA MAIN CARDS
    playerCard.valorLabel.Text = #p:GetPlayers()
    pingCard.valorLabel.Text = math.random(20,60).."ms"
    fpsCard.valorLabel.Text = math.floor(1/rs.RenderStepped:Wait())
    
    -- ATUALIZA STATUS DOS MÓDULOS
    moduleLabels["AIMBOT"].Text = a.aim and "ON" or "OFF"
    moduleLabels["AIMBOT"].TextColor3 = a.aim and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,100,100)
    moduleLabels["SILENT"].Text = a.silent and "ON" or "OFF"
    moduleLabels["SILENT"].TextColor3 = a.silent and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,100,100)
    moduleLabels["ESP"].Text = a.esp and "ON" or "OFF"
    moduleLabels["ESP"].TextColor3 = a.esp and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,100,100)
    moduleLabels["FRUTAS"].Text = a.espFrutas and "ON" or "OFF"
    moduleLabels["FRUTAS"].TextColor3 = a.espFrutas and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,100,100)
    
    -- Atualiza círculo
    if a.aim and a.fovCircle then
        circleGui.Enabled=true
        local mousePos=Vector2.new(mouse.X, mouse.Y)
        local viewport=cam.ViewportSize
        
        local x = mousePos.X - a.fov
        local y = mousePos.Y - a.fov
        
        x = math.max(0, math.min(x, viewport.X - a.fov*2))
        y = math.max(0, math.min(y, viewport.Y - a.fov*2))
        
        circleContainer.Position=UDim2.new(0,x,0,y)
        circleContainer.Size=UDim2.new(0,a.fov*2,0,a.fov*2)
        
        local targets=getTargets()
        if #targets>0 then
            outerCircle.BorderColor3=Color3.fromRGB(255,100,100)
            hLine.BackgroundColor3=Color3.fromRGB(255,100,100)
            vLine.BackgroundColor3=Color3.fromRGB(255,100,100)
            centerDot.BackgroundColor3=Color3.fromRGB(255,100,100)
        else
            outerCircle.BorderColor3=Color3.fromRGB(0,200,255)
            hLine.BackgroundColor3=Color3.fromRGB(0,200,255)
            vLine.BackgroundColor3=Color3.fromRGB(0,200,255)
            centerDot.BackgroundColor3=Color3.fromRGB(255,255,255)
        end
    else
        circleGui.Enabled=false
    end
    
    -- AIMBOT CORRIGIDO
    if a.aim then
        local targets=getTargets()
        
        if a.lockMode and currentTarget then
            local targetStillValid = false
            local targetPart = nil
            
            if currentTarget.Character and currentTarget.Character:FindFirstChild("Humanoid") and currentTarget.Character.Humanoid.Health>0 and not isAlly(currentTarget) then
                local root = currentTarget.Character:FindFirstChild("HumanoidRootPart") or currentTarget.Character:FindFirstChild("Torso")
                if root then
                    local screenPos, onScreen = cam:WorldToViewportPoint(root.Position)
                    if onScreen then
                        local mousePos = Vector2.new(mouse.X, mouse.Y)
                        local targetPos = Vector2.new(screenPos.X, screenPos.Y)
                        local distFromMouse = (targetPos - mousePos).Magnitude
                        if distFromMouse <= a.fov then
                            targetStillValid = true
                            targetPart = currentTarget.Character:FindFirstChild(a.aimPart) or root
                        end
                    end
                end
            end
            
            if targetStillValid and targetPart then
                local cameraPos = cam.CFrame.Position
                local targetPos = targetPart.Position
                local direction = (targetPos - cameraPos).Unit
                cam.CFrame = CFrame.new(cameraPos, cameraPos + direction)
            else
                currentTarget = nil
            end
        end
        
        if not currentTarget and #targets>0 then
            currentTarget = targets[1].pl
        end
        
        if not a.lockMode and #targets>0 then
            currentTarget = targets[1].pl
        end
        
        if currentTarget and currentTarget.Character then
            local parte = currentTarget.Character:FindFirstChild(a.aimPart) or currentTarget.Character:FindFirstChild("HumanoidRootPart") or currentTarget.Character:FindFirstChild("Torso")
            if parte then
                local cameraPos = cam.CFrame.Position
                local targetPos = parte.Position
                local direction = (targetPos - cameraPos).Unit
                cam.CFrame = CFrame.new(cameraPos, cameraPos + direction)
            end
        end
    end
    
    -- SILENT AIM CORRIGIDO
    if a.silent and currentTarget and currentTarget.Character then
        local parte = currentTarget.Character:FindFirstChild(a.hitpart) or currentTarget.Character:FindFirstChild("HumanoidRootPart")
        if parte and not silentHooked then
            silentHooked = true
            local mt = getrawmetatable(game)
            local old = mt.__namecall
            setreadonly(mt, false)
            
            mt.__namecall = function(self, ...)
                local args = {...}
                local method = getnamecallmethod()
                
                if a.silent and currentTarget and (method == "FireServer" or method == "InvokeServer") then
                    local parte = currentTarget.Character:FindFirstChild(a.hitpart) or currentTarget.Character:FindFirstChild("HumanoidRootPart")
                    if parte then
                        for i = 1, #args do
                            if type(args[i]) == "Vector3" then
                                args[i] = parte.Position
                                break
                            elseif type(args[i]) == "CFrame" then
                                args[i] = CFrame.new(parte.Position)
                                break
                            end
                        end
                    end
                end
                
                return old(self, unpack(args))
            end
            
            setreadonly(mt, true)
        end
    end
    
    -- ESP DE JOGADORES CORRIGIDO
    if a.esp then
        local espPlayers=getESPPlayers()
        local espCount=0
        
        for _,data in ipairs(espPlayers) do
            local esp=espTags[data.pl]
            if esp and data.root then
                local screenPos, onScreen=cam:WorldToViewportPoint(data.root.Position)
                
                if onScreen then
                    esp.bill.Adornee=data.root
                    esp.bill.Enabled=true
                    espCount=espCount+1
                    
                    local ally=isAlly(data.pl)
                    local isTarget = (currentTarget == data.pl)
                    local color = isTarget and Color3.fromRGB(255,255,0) or (ally and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,100,100))
                    
                    esp.name.TextColor3=color
                    esp.name.Text=(isTarget and "🎯 " or (ally and "🟢 " or "🔴 "))..data.pl.Name
                    esp.dist.Text=math.floor(data.dist).."m"
                    esp.dist.TextColor3=color
                else
                    esp.bill.Enabled=false
                end
            end
        end
        
        for pl,esp in pairs(espTags) do
            local found=false
            for _,data in ipairs(espPlayers) do
                if data.pl==pl then found=true break end
            end
            if not found then
                esp.bill.Enabled=false
            end
        end
    else
        for _,esp in pairs(espTags) do
            esp.bill.Enabled=false
        end
    end
    
    -- ESP DE FRUTAS CORRIGIDO
    if a.espFrutas then
        local frutasProximas=getFrutasProximas()
        
        for _,data in ipairs(frutasProximas) do
            local screenPos, onScreen=cam:WorldToViewportPoint(data.obj.Position)
            
            if onScreen then
                data.bill.Adornee=data.obj
                data.bill.Enabled=true
                
                local frame = data.bill:FindFirstChildWhichIsA("Frame")
                if frame then
                    local distLabel = frame:FindFirstChildWhichIsA("TextLabel")
                    if distLabel and distLabel.Position==UDim2.new(0,0,0.5,-2) then
                        distLabel.Text=math.floor(data.dist).."m"
                    end
                end
            else
                data.bill.Enabled=false
            end
        end
    else
        for _,bill in pairs(frutaTags) do
            bill.Enabled=false
        end
    end
end)

