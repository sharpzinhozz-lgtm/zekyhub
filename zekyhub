-- ========== FUNÇÕES AUXILIARES ==========
local function isAlly(pl)
    if a.team == "" then return false end
    local name = pl.Name:lower()
    if a.team == "MARINHA" and (name:find("marine") or name:find("marinha")) then return true end
    if a.team == "PIRATA" and (name:find("pirata") or name:find("pirate")) then return true end
    return false
end

local function getTargets()
    local targets = {}
    local cameraPos = Camera.CFrame.Position
    local mousePos = Vector2New(Mouse.X, Mouse.Y)
    
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= LocalPlayer and pl.Character and pl.Character:FindFirstChild("Humanoid") and pl.Character.Humanoid.Health > 0 and not isAlly(pl) then
            local root = pl.Character:FindFirstChild("HumanoidRootPart") or pl.Character:FindFirstChild("Torso")
            if root then
                local dist3D = (root.Position - cameraPos).Magnitude
                if dist3D <= a.dist then  -- Agora sempre true com 9999
                    local screenPos, onScreen = WorldToViewportPoint(Camera, root.Position)
                    if onScreen then
                        local distFromMouse = (Vector2New(screenPos.X, screenPos.Y) - mousePos).Magnitude
                        if distFromMouse <= a.fov then
                            table_insert(targets, {
                                pl = pl,
                                root = root,
                                dist2D = distFromMouse,
                                dist3D = dist3D
                            })
                        end
                    end
                end
            end
        end
    end
    
    table_sort(targets, function(x, y) return x.dist2D < y.dist2D end)
    return targets
end

-- ========== LOOP PRINCIPAL OTIMIZADO ==========
RunService.RenderStepped:Connect(function()
    -- Atualiza stats a cada 10 frames
    frameCount = frameCount + 1
    if frameCount % 10 == 0 then
        local now = tick()
        if now - lastFPSCalc >= 1 then
            currentFPS = frameCount
            frameCount = 0
            lastFPSCalc = now
            pingSim = math.random(20, 60)
        end
        playerValor.Text = #Players:GetPlayers()
        pingValor.Text = pingSim.."ms"
        fpsValor.Text = currentFPS
    end
    
    -- Atualiza status dos módulos
    moduleLabels.AIMBOT.Text = a.aim and "ON" or "OFF"
    moduleLabels.AIMBOT.TextColor3 = a.aim and Color3RGB(0, 255, 0) or Color3RGB(255, 100, 100)
    moduleLabels.SILENT.Text = a.silent and "ON" or "OFF"
    moduleLabels.SILENT.TextColor3 = a.silent and Color3RGB(0, 255, 0) or Color3RGB(255, 100, 100)
    moduleLabels.ESP.Text = a.esp and "ON" or "OFF"
    moduleLabels.ESP.TextColor3 = a.esp and Color3RGB(0, 255, 0) or Color3RGB(255, 100, 100)
    moduleLabels.FRUTAS.Text = a.espFrutas and "ON" or "OFF"
    moduleLabels.FRUTAS.TextColor3 = a.espFrutas and Color3RGB(0, 255, 0) or Color3RGB(255, 100, 100)
    
    -- FOV Circle
    if a.aim and a.fovCircle then
        circleGui.Enabled = true
        local x = math_clamp(Mouse.X - a.fov, 0, Camera.ViewportSize.X - a.fov*2)
        local y = math_clamp(Mouse.Y - a.fov, 0, Camera.ViewportSize.Y - a.fov*2)
        circleContainer.Position = UDim2New(0, x, 0, y)
        circleContainer.Size = UDim2New(0, a.fov*2, 0, a.fov*2)
        
        local targets = getTargets()
        local color = #targets > 0 and Color3RGB(255, 100, 100) or Color3RGB(0, 200, 255)
        outerCircle.BorderColor3 = color
    else
        circleGui.Enabled = false
    end
    
    -- AIMBOT
    if a.aim then
        local targets = getTargets()
        
        if a.lockMode and currentTarget then
            if currentTarget.Character and currentTarget.Character:FindFirstChild("Humanoid") and currentTarget.Character.Humanoid.Health > 0 and not isAlly(currentTarget) then
                local root = currentTarget.Character:FindFirstChild("HumanoidRootPart") or currentTarget.Character:FindFirstChild("Torso")
                if root then
                    local screenPos, onScreen = WorldToViewportPoint(Camera, root.Position)
                    if onScreen then
                        local distFromMouse = (Vector2New(screenPos.X, screenPos.Y) - Vector2New(Mouse.X, Mouse.Y)).Magnitude
                        if distFromMouse <= a.fov then
                            local parte = currentTarget.Character:FindFirstChild(a.aimPart) or root
                            local direction = (parte.Position - Camera.CFrame.Position).Unit
                            Camera.CFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + direction)
                        else
                            currentTarget = nil
                        end
                    else
                        currentTarget = nil
                    end
                else
                    currentTarget = nil
                end
            else
                currentTarget = nil
            end
        end
        
        if not currentTarget and #targets > 0 then
            currentTarget = targets[1].pl
        end
        
        if not a.lockMode and #targets > 0 then
            currentTarget = targets[1].pl
        end
        
        if currentTarget and currentTarget.Character then
            local parte = currentTarget.Character:FindFirstChild(a.aimPart) or currentTarget.Character:FindFirstChild("HumanoidRootPart") or currentTarget.Character:FindFirstChild("Torso")
            if parte then
                local direction = (parte.Position - Camera.CFrame.Position).Unit
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + direction)
            end
        end
    end
    
    -- ESP
    if a.esp then
        for pl, data in pairs(espTags) do
            if pl.Character and pl.Character:FindFirstChild("Humanoid") and pl.Character.Humanoid.Health > 0 then
                local root = pl.Character:FindFirstChild("HumanoidRootPart") or pl.Character:FindFirstChild("Torso")
                if root then
                    local dist = (root.Position - Camera.CFrame.Position).Magnitude
                    if dist <= a.espDist then  -- Agora sempre true com 9999
                        local screenPos, onScreen = WorldToViewportPoint(Camera, root.Position)
                        if onScreen then
                            data.bill.Adornee = root
                            data.bill.Enabled = true
                            
                            local ally = isAlly(pl)
                            local isTarget = (currentTarget == pl)
                            local color = isTarget and Color3RGB(255, 255, 0) or (ally and Color3RGB(0, 255, 0) or Color3RGB(255, 100, 100))
                            
                            data.name.TextColor3 = color
                            data.name.Text = (isTarget and "🎯 " or (ally and "🟢 " or "🔴 "))..pl.Name
                            data.dist.Text = math_floor(dist).."m"
                            data.dist.TextColor3 = color
                        else
                            data.bill.Enabled = false
                        end
                    else
                        data.bill.Enabled = false
                    end
                else
                    data.bill.Enabled = false
                end
            else
                data.bill.Enabled = false
            end
        end
    else
        for _, data in pairs(espTags) do
            data.bill.Enabled = false
        end
    end
    
    -- ESP de Frutas
    if a.espFrutas then
        for obj, bill in pairs(frutaTags) do
            if obj and obj.Parent then
                local dist = (obj.Position - Camera.CFrame.Position).Magnitude
                if dist <= a.frutaDist then  -- Agora sempre true com 9999
                    local screenPos, onScreen = WorldToViewportPoint(Camera, obj.Position)
                    if onScreen then
                        bill.Adornee = obj
                        bill.Enabled = true
                        
                        local frame = bill:FindFirstChildWhichIsA("Frame")
                        if frame then
                            local distLabel = frame:FindFirstChildWhichIsA("TextLabel")
                            if distLabel and distLabel.Position == UDim2New(0, 0, 0.6, -2) then
                                distLabel.Text = math_floor(dist).."m"
                            end
                        end
                    else
                        bill.Enabled = false
                    end
                else
                    bill.Enabled = false
                end
            else
                bill.Enabled = false
            end
        end
    else
        for _, bill in pairs(frutaTags) do
            bill.Enabled = false
        end
    end
end)

