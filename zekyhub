-- ========== ESP FRUTAS ==========
local function criarESPFruta(obj)
    if frutaTags[obj] then return end
    
    local nome = string_lower(obj.Name)
    local isFruit = false
    for palavra, _ in pairs(frutaPalavras) do
        if string_find(nome, palavra) then
            isFruit = true
            break
        end
    end
    
    if not isFruit and (obj:IsA("Tool") or obj:IsA("Part") or obj:IsA("MeshPart")) then
        if obj:FindFirstChild("Handle") then isFruit = true end
    end
    
    if not isFruit then return end
    
    local bill = Instance.new("BillboardGui")
    bill.Name = "FrutaESP_"..obj.Name
    bill.Size = UDim2New(0, 65, 0, 22)
    bill.StudsOffset = Vector3.new(0, 1.5, 0)
    bill.AlwaysOnTop = true
    bill.Enabled = false
    bill.Parent = guiParent
    bill.ResetOnSpawn = false
    
    local bg = Instance.new("Frame", bill)
    bg.Size = UDim2New(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3RGB(255, 130, 30)
    bg.BackgroundTransparency = 0.15
    bg.BorderSizePixel = 2
    bg.BorderColor3 = Color3RGB(255, 200, 50)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 5)
    
    local text = Instance.new("TextLabel", bg)
    text.Size = UDim2New(1, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.Text = "🍎 FRUTA"
    text.TextColor3 = Color3RGB(255, 255, 255)
    text.TextSize = 10
    text.Font = Enum.Font.GothamBold
    
    frutaTags[obj] = bill
end

