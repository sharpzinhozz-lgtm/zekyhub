local function createGui()
    local parent = CoreGui
    local success = pcall(function() 
        local test = Instance.new("ScreenGui")
        test.Parent = parent
        test:Destroy()
    end)
    return success and parent or LocalPlayer:FindFirstChild("PlayerGui") or Instance.new("ScreenGui")
end

