    if gameProcessed then return end
    
    if a.keyMode == "HOLD" and input.KeyCode == a.keybind then
        a.aim = false
        aimToggle.Text = "OFF"
        aimToggle.BackgroundColor3 = Color3RGB(150, 50, 50)
        currentTarget = nil
    end
end)

