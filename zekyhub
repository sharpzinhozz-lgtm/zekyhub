-- ========== FUNÇÃO PARA CRIAR SLIDER ==========
local function criarSlider(parent, nome, valor, y)
    local bg = Instance.new("Frame", parent)
    bg.Size = UDim2New(0.9, 0, 0, 35)
    bg.Position = UDim2New(0, 0, 0, y)
    bg.BackgroundTransparency = 1
    
    local label = Instance.new("TextLabel", bg)
    label.Size = UDim2New(0.4, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = nome
    label.TextColor3 = Color3RGB(200, 200, 200)
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local box = Instance.new("TextBox", bg)
    box.Size = UDim2New(0.25, 0, 0, 25)
    box.Position = UDim2New(0.65, 0, 0.5, -12.5)
    box.BackgroundColor3 = Color3RGB(30, 30, 50)
    box.BackgroundTransparency = 0.3
    box.Text = tostring(valor)
    box.TextColor3 = Color3RGB(0, 255, 200)
    box.TextSize = 12
    box.Font = Enum.Font.Gotham
    box.ClearTextOnFocus = false
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)
    
    return box
end

-- ========== FUNÇÃO PARA CRIAR TOGGLE ==========
local function criarToggle(parent, texto, estado, y)
    local bg = Instance.new("Frame", parent)
    bg.Size = UDim2New(0.9, 0, 0, 30)
    bg.Position = UDim2New(0, 0, 0, y)
    bg.BackgroundTransparency = 1
    
    local label = Instance.new("TextLabel", bg)
    label.Size = UDim2New(0.7, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = texto
    label.TextColor3 = Color3RGB(255, 255, 255)
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local btn = Instance.new("TextButton", bg)
    btn.Size = UDim2New(0.2, 0, 0, 25)
    btn.Position = UDim2New(0.7, 0, 0.5, -12.5)
    btn.BackgroundColor3 = estado and Color3RGB(0, 150, 0) or Color3RGB(150, 50, 50)
    btn.Text = estado and "ON" or "OFF"
    btn.TextColor3 = Color3RGB(255, 255, 255)
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    return btn
end

