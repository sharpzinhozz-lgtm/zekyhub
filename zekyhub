-- ========== FUNÇÕES AUXILIARES ==========
local function isAlly(pl)
    if a.team == "" then return false end
    local name = string_lower(pl.Name)
    if a.team == "MARINHA" and (string_find(name, "marine") or string_find(name, "marinha")) then return true end
    if a.team == "PIRATA" and (string_find(name, "pirata") or string_find(name, "pirate")) then return true end
    return false
end

local function getTargets()
    local targets = {}
    local cameraPos = Camera.CFrame.Position
    local mousePos = Vector2New(Mouse.X, Mouse.Y)
    local fovSq = a.fov * a.fov
    
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= LocalPlayer and pl.Character and pl.Character:FindFirstChild("Humanoid") and pl.Character.Humanoid.Health > 0 and not isAlly(pl) then
            local root = pl.Character:FindFirstChild("HumanoidRootPart") or pl.Character:FindFirstChild("Torso")
            if root then
                local dist3D = (root.Position - cameraPos).Magnitude
                if dist3D <= a.dist then
                    local screenPos, onScreen = WorldToViewportPoint(Camera, root.Position)
                    if onScreen then
                        local dx = screenPos.X - mousePos.X
                        local dy = screenPos.Y - mousePos.Y
                        if dx*dx + dy*dy <= fovSq then
                            table_insert(targets, {pl = pl, root = root})
                        end
                    end
                end
            end
        end
    end
    return targets
end

-- ========== LOOP PRINCIPAL ==========
RunService.RenderStepped:Connect(function()
    local now = tick()
    
    -- Stats a cada 0.3 segundos
    if now - lastStatUpdate > 0.3 then
        lastStatUpdate = now
        frameCount = frameCount + 1
        if now - fpsTimer >= 1 then
            currentFPS = frameCount
            frameCount = 0
            fpsTimer = now
            pingSim = math_random(20, 60)
        end
        
        playerStat.Text = "👥 "..#Players:GetPlayers()
        pingStat.Text = "📶 "..pingSim.."ms"
        fpsStat.Text = "⚡ "..currentFPS
        
        moduleLabels.AIM.Text = a.aim and "ON" or "OFF"
        moduleLabels.AIM.TextColor3 = a.aim and Color3RGB(0, 200, 0) or Color3RGB(200, 70, 70)
        moduleLabels.SILENT.Text = a.silent and "ON" or "OFF"
        moduleLabels.SILENT.TextColor3 = a.silent and Color3RGB(0, 200, 0) or Color3RGB(200, 70, 70)
        moduleLabels.ESP.Text = a.esp and "ON" or "OFF"
        moduleLabels.ESP.TextColor3 = a.esp and Color3RGB(0, 200, 0) or Color3RGB(200, 70, 70)
        moduleLabels.FRUTAS.Text = a.espFrutas and "ON" or "OFF"
        moduleLabels.FRUTAS.TextColor3 = a.espFrutas and Color3RGB(0, 200, 0) or Color3RGB(200, 70, 70)
    end
    
    -- Círculo FOV
    if a.aim and a.fovCircle then
        circleGui.Enabled = true
        local x = math_clamp(Mouse.X - a.fov, 0, Camera.ViewportSize.X - a.fov*2)
        local y = math_clamp(Mouse.Y - a.fov, 0, Camera.ViewportSize.Y - a.fov*2)
        circle.Position = UDim2New(0, x, 0, y)
        circle.Size = UDim2New(0, a.fov*2, 0, a.fov*2)
        circle.BorderColor3 = #getTargets() > 0 and Color3RGB(255, 100, 100) or Color3RGB(0, 200, 255)
    else
        circleGui.Enabled = false
    end
    
    -- AIMBOT com LOCK-ON
    if a.aim then
        local targets = getTargets()
        
        if a.lockMode and currentTarget then
            if currentTarget.Character and currentTarget.Character:FindFirstChild("Humanoid") and currentTarget.Character.Humanoid.Health > 0 and not isAlly(currentTarget) then
                local root = currentTarget.Character:FindFirstChild("HumanoidRootPart") or currentTarget.Character:FindFirstChild("Torso")
                if root then
                    local screenPos, onScreen = WorldToViewportPoint(Camera, root.Position)
                    if onScreen then
                        local dx = screenPos.X - Mouse.X
                        local dy = screenPos.Y - Mouse.Y
                        if dx*dx + dy*dy <= a.fov*a.fov then
                            local part = currentTarget.Character:FindFirstChild(a.aimPart) or root
                            Camera.CFrame = CFrame_new(Camera.CFrame.Position, part.Position)
                        else
                            currentTarget = nil
                        end
                    else
                        currentTarget = nil
                    end
                else
                    currentTarget = nil
                end
            else
                currentTarget = nil
            end
        end
        
        if not currentTarget and #targets > 0 then
            currentTarget = targets[1].pl
        end
        
        if not a.lockMode and #targets > 0 then
            currentTarget = targets[1].pl
        end
        
        if currentTarget and currentTarget.Character then
            local part = currentTarget.Character:FindFirstChild(a.aimPart) or currentTarget.Character:FindFirstChild("HumanoidRootPart") or currentTarget.Character:FindFirstChild("Torso")
            if part then
                Camera.CFrame = CFrame_new(Camera.CFrame.Position, part.Position)
            end
        end
    end
    
    -- ESP (a cada 2 frames)
    espUpdateCounter = espUpdateCounter + 1
    if espUpdateCounter % 2 == 0 then
        -- ESP Jogadores
        if a.esp then
            for pl, d in pairs(espTags) do
                if pl.Character and pl.Character:FindFirstChild("Humanoid") and pl.Character.Humanoid.Health > 0 then
                    local root = pl.Character:FindFirstChild("HumanoidRootPart") or pl.Character:FindFirstChild("Torso")
                    if root then
                        local dist = (root.Position - Camera.CFrame.Position).Magnitude
                        if dist <= a.espDist then
                            local screenPos, onScreen = WorldToViewportPoint(Camera, root.Position)
                            if onScreen then
                                d.bill.Adornee = root
                                d.bill.Enabled = true
                                local ally = isAlly(pl)
                                local isTarget = (currentTarget == pl)
                                d.label.TextColor3 = isTarget and Color3RGB(255, 220, 0) or (ally and Color3RGB(0, 220, 0) or Color3RGB(220, 70, 70))
                                d.label.Text = (isTarget and "🎯 " or (ally and "🟢 " or "🔴 "))..pl.Name
                            else
                                d.bill.Enabled = false
                            end
                        else
                            d.bill.Enabled = false
                        end
                    else
                        d.bill.Enabled = false
                    end
                else
                    d.bill.Enabled = false
                end
            end
        else
            for _, d in pairs(espTags) do
                d.bill.Enabled = false
            end
        end
        
        -- ESP Frutas
        if a.espFrutas then
            for obj, bill in pairs(frutaTags) do
                if obj and obj.Parent then
                    local dist = (obj.Position - Camera.CFrame.Position).Magnitude
                    if dist <= a.frutaDist then
                        local screenPos, onScreen = WorldToViewportPoint(Camera, obj.Position)
                        if onScreen then
                            bill.Adornee = obj
                            bill.Enabled = true
                        else
                            bill.Enabled = false
                        end
                    else
                        bill.Enabled = false
                    end
                else
                    bill.Enabled = false
                end
            end
        else
            for _, bill in pairs(frutaTags) do
                bill.Enabled = false
            end
        end
    end
end)

