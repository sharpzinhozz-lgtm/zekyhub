-- ========== FUNÇÕES AUXILIARES (OTIMIZADAS) ==========
local function isAlly(pl)
    if a.team == "" then return false end
    local name = pl.Name:lower()
    if a.team == "MARINHA" and (name:find("marine") or name:find("marinha")) then return true end
    if a.team == "PIRATA" and (name:find("pirata") or name:find("pirate")) then return true end
    return false
end

local function getTargets()
    local targets = {}
    local cameraPos = Camera.CFrame.Position
    local mousePos = Vector2New(Mouse.X, Mouse.Y)
    local fovSq = a.fov * a.fov  -- Usa quadrado para evitar sqrt
    
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= LocalPlayer and pl.Character and pl.Character:FindFirstChild("Humanoid") and pl.Character.Humanoid.Health > 0 and not isAlly(pl) then
            local root = pl.Character:FindFirstChild("HumanoidRootPart") or pl.Character:FindFirstChild("Torso")
            if root then
                local dist3D = (root.Position - cameraPos).Magnitude
                if dist3D <= a.dist then
                    local screenPos, onScreen = WorldToViewportPoint(Camera, root.Position)
                    if onScreen then
                        local dx = screenPos.X - mousePos.X
                        local dy = screenPos.Y - mousePos.Y
                        local distFromMouseSq = dx*dx + dy*dy
                        if distFromMouseSq <= fovSq then
                            table_insert(targets, {
                                pl = pl,
                                root = root,
                                dist2D = math_sqrt and math.sqrt(distFromMouseSq) or distFromMouseSq,
                                dist3D = dist3D
                            })
                        end
                    end
                end
            end
        end
    end
    
    table_sort(targets, function(x, y) return x.dist2D < y.dist2D end)
    return targets
end

-- ========== LOOP PRINCIPAL ULTRA OTIMIZADO ==========
RunService.RenderStepped:Connect(function()
    local now = tick()
    
    -- Atualiza stats a cada 0.2 segundos (5x por segundo)
    if now - lastUpdate > 0.2 then
        lastUpdate = now
        
        -- FPS
        frameCount = frameCount + 1
        if now - fpsTimer >= 1 then
            currentFPS = frameCount
            frameCount = 0
            fpsTimer = now
        end
        
        -- Update UI
        playerStat.Text = "👥 "..#Players:GetPlayers()
        pingStat.Text = "📶 "..math_random(20, 60).."ms"
        fpsStat.Text = "⚡ "..currentFPS
        
        -- Module status
        moduleLabels.AIM.Text = a.aim and "ON" or "OFF"
        moduleLabels.AIM.TextColor3 = a.aim and Color3RGB(0, 180, 0) or Color3RGB(180, 60, 60)
        moduleLabels.SILENT.Text = a.silent and "ON" or "OFF"
        moduleLabels.SILENT.TextColor3 = a.silent and Color3RGB(0, 180, 0) or Color3RGB(180, 60, 60)
        moduleLabels.ESP.Text = a.esp and "ON" or "OFF"
        moduleLabels.ESP.TextColor3 = a.esp and Color3RGB(0, 180, 0) or Color3RGB(180, 60, 60)
        moduleLabels.FRUTAS.Text = a.espFrutas and "ON" or "OFF"
        moduleLabels.FRUTAS.TextColor3 = a.espFrutas and Color3RGB(0, 180, 0) or Color3RGB(180, 60, 60)
    end
    
    -- FOV Circle (sempre atualiza se ativo)
    if a.aim and a.fovCircle then
        circleGui.Enabled = true
        local x = math_clamp(Mouse.X - a.fov, 0, Camera.ViewportSize.X - a.fov*2)
        local y = math_clamp(Mouse.Y - a.fov, 0, Camera.ViewportSize.Y - a.fov*2)
        circleContainer.Position = UDim2New(0, x, 0, y)
        circleContainer.Size = UDim2New(0, a.fov*2, 0, a.fov*2)
    else
        circleGui.Enabled = false
    end
    
    -- AIMBOT (executa sempre)
    if a.aim then
        local targets = getTargets()
        
        if a.lockMode and currentTarget then
            if currentTarget.Character and currentTarget.Character:FindFirstChild("Humanoid") and currentTarget.Character.Humanoid.Health > 0 and not isAlly(currentTarget) then
                local root = currentTarget.Character:FindFirstChild("HumanoidRootPart") or currentTarget.Character:FindFirstChild("Torso")
                if root then
                    local screenPos, onScreen = WorldToViewportPoint(Camera, root.Position)
                    if onScreen then
                        local dx = screenPos.X - Mouse.X
                        local dy = screenPos.Y - Mouse.Y
                        if dx*dx + dy*dy <= a.fov*a.fov then
                            local parte = currentTarget.Character:FindFirstChild(a.aimPart) or root
                            local direction = (parte.Position - Camera.CFrame.Position).Unit
                            Camera.CFrame = CFrame_new(Camera.CFrame.Position, Camera.CFrame.Position + direction)
                        else
                            currentTarget = nil
                        end
                    else
                        currentTarget = nil
                    end
                else
                    currentTarget = nil
                end
            else
                currentTarget = nil
            end
        end
        
        if not currentTarget and #targets > 0 then
            currentTarget = targets[1].pl
        end
        
        if not a.lockMode and #targets > 0 then
            currentTarget = targets[1].pl
        end
        
        if currentTarget and currentTarget.Character then
            local parte = currentTarget.Character:FindFirstChild(a.aimPart) or currentTarget.Character:FindFirstChild("HumanoidRootPart") or currentTarget.Character:FindFirstChild("Torso")
            if parte then
                local direction = (parte.Position - Camera.CFrame.Position).Unit
                Camera.CFrame = CFrame_new(Camera.CFrame.Position, Camera.CFrame.Position + direction)
            end
        end
    end
    
    -- ESP (executa a cada 2 frames para economizar)
    espUpdateCounter = espUpdateCounter + 1
    if espUpdateCounter % 2 == 0 then
        if a.esp then
            for pl, data in pairs(espTags) do
                if pl.Character and pl.Character:FindFirstChild("Humanoid") and pl.Character.Humanoid.Health > 0 then
                    local root = pl.Character:FindFirstChild("HumanoidRootPart") or pl.Character:FindFirstChild("Torso")
                    if root then
                        local dist = (root.Position - Camera.CFrame.Position).Magnitude
                        if dist <= a.espDist then
                            local screenPos, onScreen = WorldToViewportPoint(Camera, root.Position)
                            if onScreen then
                                data.bill.Adornee = root
                                data.bill.Enabled = true
                                
                                local ally = isAlly(pl)
                                local isTarget = (currentTarget == pl)
                                local color = isTarget and Color3RGB(255, 200, 0) or (ally and Color3RGB(0, 200, 0) or Color3RGB(200, 60, 60))
                                
                                data.label.TextColor3 = color
                                data.label.Text = (isTarget and "🎯 " or (ally and "🟢 " or "🔴 "))..pl.Name
                            else
                                data.bill.Enabled = false
                            end
                        else
                            data.bill.Enabled = false
                        end
                    else
                        data.bill.Enabled = false
                    end
                else
                    data.bill.Enabled = false
                end
            end
        else
            for _, data in pairs(espTags) do
                data.bill.Enabled = false
            end
        end
    end
end)

