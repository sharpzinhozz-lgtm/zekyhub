-- ========== FUNÇÕES DE UI ==========
local function criarSlider(parent, nome, valor, min, max, y)
    local bg = Instance.new("Frame", parent)
    bg.Size = UDim2New(0.9, 0, 0, 30)
    bg.Position = UDim2New(0.05, 0, 0, y)
    bg.BackgroundTransparency = 1
    
    local label = Instance.new("TextLabel", bg)
    label.Size = UDim2New(0.55, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = nome.." ("..min.."-"..max..")"
    label.TextColor3 = Color3RGB(200, 200, 200)
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    
    local box = Instance.new("TextBox", bg)
    box.Size = UDim2New(0.3, 0, 0, 22)
    box.Position = UDim2New(0.65, 0, 0.5, -11)
    box.BackgroundColor3 = Color3RGB(30, 30, 40)
    box.BackgroundTransparency = 0.3
    box.Text = tostring(valor)
    box.TextColor3 = Color3RGB(0, 255, 200)
    box.TextSize = 11
    box.Font = Enum.Font.Gotham
    box.ClearTextOnFocus = false
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 5)
    
    return box
end

local function criarToggle(parent, texto, estado, y)
    local bg = Instance.new("Frame", parent)
    bg.Size = UDim2New(0.9, 0, 0, 24)
    bg.Position = UDim2New(0.05, 0, 0, y)
    bg.BackgroundTransparency = 1
    
    local label = Instance.new("TextLabel", bg)
    label.Size = UDim2New(0.65, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = texto
    label.TextColor3 = Color3RGB(220, 220, 220)
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    
    local btn = Instance.new("TextButton", bg)
    btn.Size = UDim2New(0.25, 0, 0, 20)
    btn.Position = UDim2New(0.7, 0, 0.5, -10)
    btn.BackgroundColor3 = estado and Color3RGB(0, 100, 0) or Color3RGB(100, 40, 40)
    btn.Text = estado and "ON" or "OFF"
    btn.TextColor3 = Color3RGB(255, 255, 255)
    btn.TextSize = 10
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
    
    return btn
end

